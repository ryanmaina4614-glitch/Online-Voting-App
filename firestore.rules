rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // 1. Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.email is string && data.email.size() < 256 &&
               data.displayName is string && data.displayName.size() < 128 &&
               data.role in ['voter', 'admin'] &&
               data.votedElections is list &&
               (!('age' in data) || data.age is number) &&
               (!('classGroup' in data) || (data.classGroup is string && data.classGroup.size() < 100)) &&
               (!('gender' in data) || (data.gender is string && data.gender.size() < 50));
      }
      
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'voter';
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'votedElections']);
    }

    // 2. Elections Collection
    match /elections/{electionId} {
      function isValidElection(data) {
        return data.title is string && data.title.size() > 0 &&
               data.status in ['upcoming', 'active', 'completed'] &&
               data.candidates is list &&
               data.totalVotes is number;
      }
      
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidElection(incoming());
      allow update: if (isAdmin() && isValidElection(incoming())) ||
                    (isSignedIn() && isValidElection(incoming()) && 
                     incoming().diff(existing()).affectedKeys().hasOnly(['candidates', 'totalVotes']));
    }

    // 3. Vote Records (Relational Sync)
    // To prevent double voting: a user can only create a record for themselves
    match /voteRecords/{recordId} {
      function isValidRecord(data) {
        return data.voterId == request.auth.uid &&
               data.electionId is string &&
               data.timestamp == request.time;
      }
      
      allow get: if isOwner(existing().voterId) || isAdmin();
      allow list: if isAdmin() || (isSignedIn() && resource.data.voterId == request.auth.uid);
      allow create: if isSignedIn() && isValidRecord(incoming()) && 
                    !exists(/databases/$(database)/documents/voteRecords/$(incoming().voterId + '_' + incoming().electionId));
    }

    // 4. Anonymous Votes
    match /anonymousVotes/{voteId} {
      function isValidVote(data) {
        return data.electionId is string &&
               data.candidateId is string &&
               data.timestamp == request.time;
      }
      
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidVote(incoming());
    }
    
    // 5. Admins Collection
    match /admins/{userId} {
      allow read: if isSignedIn();
    }
  }
}
